{"__ud_title":"编写属于你自己的账单小组件","__ud_tags":["Cent"],"__ud_update_time":1778736828818,"__ud_create_time":1778065040673,"__ud_draft":false,"type":"doc","content":[{"type":"heading","attrs":{"level":1,"id":"编写属于你自己的账单小组件"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"编写属于你自己的账单小组件"}]},{"type":"paragraph","content":[{"type":"text","text":"Cent 1.5引入了全新的 Widget 系统，允许你用一小段 JavaScript 脚本读取账本数据、渲染轻量 UI，并通过配置表单把组件参数暴露给最终用户。本文面向开发者和高级用户，介绍 Widget 能做什么、权限与数据模型、如何编写最小可运行示例，以及在 Cent 编辑器里调试与发布的实用步骤。"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"为什么要用 Widget？"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"可视化你关心的统计：自定义支出聚合、分类排行、预算进度等。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"轻量而安全：DSL 渲染（"},{"type":"text","marks":[{"type":"code"}],"text":"Flex"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"Text"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"Container"},{"type":"text","text":" 等）避免直接操作 DOM，执行环境做了权限与 API 限制。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"用户可配置：通过 "},{"type":"text","marks":[{"type":"code"}],"text":"export const config"},{"type":"text","text":" 自动生成表单，让非开发者也能调整展示参数。"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"核心概念速览"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"元数据与权限：通过文件头部的 JSDoc 注释声明 "},{"type":"text","marks":[{"type":"code"}],"text":"@widget-api"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"@name"},{"type":"text","text":" 与 "},{"type":"text","marks":[{"type":"code"}],"text":"@permissions"},{"type":"text","text":"，未声明的权限在运行时将不会注入对应数据。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"config"},{"type":"text","text":"：导出对象，用于定义配置表单（支持 "},{"type":"text","marks":[{"type":"code"}],"text":"text"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"number"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"date"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"select"},{"type":"text","text":"）。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"渲染函数：脚本必须默认导出一个 "},{"type":"text","marks":[{"type":"code"}],"text":"async"},{"type":"text","text":" 函数，签名为 "},{"type":"text","marks":[{"type":"code"}],"text":"async (context) => DSL"},{"type":"text","text":"，接收 "},{"type":"text","marks":[{"type":"code"}],"text":"context.data"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"context.settings"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"context.env"},{"type":"text","text":"。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"DSL：使用 "},{"type":"text","marks":[{"type":"code"}],"text":"Flex"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"Text"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"Container"},{"type":"text","text":" 等链式 API 返回 UI 描述，由 Cent 内部渲染为真实 React 组件。"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"更多技术细节与权限表请参见仓库内的规范："},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://github.com/glink25/Cent/blob/main/src/components/widget/core/WIDGET_API.md","target":"_blank","rel":"noreferer","class":null}}],"text":"src/components/widget/core/WIDGET_API.md"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"最小可运行示例"},{"type":"text","text":" 下面的示例展示了一个简单的“账单总额”组件：它声明了 "},{"type":"text","marks":[{"type":"code"}],"text":"billing"},{"type":"text","text":" 权限、定义了一个可配置的标题，并在渲染函数中从 "},{"type":"text","marks":[{"type":"code"}],"text":"context.data.billing"},{"type":"text","text":" 计算总额。"}]},{"type":"codeBlock","attrs":{"language":"javascript"},"content":[{"type":"text","text":"/**\n * @widget-api 1.0\n * @name 账单总额（示例）\n * @permissions billing\n */\n\nexport const config = {\n  title: { type: 'text', label: '标题', default: '我的账单总额' },\n  startDate: { type: 'date', label: '开始日期' }\n};\n\nexport default async ({ data, settings, env }) => {\n  const bills = (data && data.billing) || [];\n  const start = settings.startDate ? new Date(settings.startDate) : null;\n  const filtered = start ? bills.filter(b => new Date(b.time) >= start) : bills;\n  const total = filtered.reduce((s, b) => s + (b.amount || 0), 0);\n\n  return Flex(\n    Text(settings.title || '账单总额').fontSize(16).bold(),\n    Text('总金额：' + total).fontSize(14).color('#333')\n  ).direction('column').gap(8);\n};\n"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"如何在 Cent 编辑器中调试（3 步）"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"打开 "},{"type":"text","marks":[{"type":"code"}],"text":"设置 → Widget 设置"},{"type":"text","text":"，点击“新增 Widget”或编辑已有 Widget，粘贴上面的代码。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"在编辑器右侧的权限栏勾选 "},{"type":"text","marks":[{"type":"code"}],"text":"billing"},{"type":"text","text":"（若编辑器提示需要），在表单区填写 "},{"type":"text","marks":[{"type":"code"}],"text":"startDate"},{"type":"text","text":" 或保留默认值。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"观察预览区，编辑器会在你修改后约 500ms 防抖后自动运行并更新预览；若出错，编辑器会显示错误信息与堆栈，方便定位。"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"关于权限与数据"},{"type":"text","text":" Widget 的数据注入严格根据头部注释声明的权限提供。例如声明 "},{"type":"text","marks":[{"type":"code"}],"text":"@permissions billing, category"},{"type":"text","text":" 将允许你的脚本通过 "},{"type":"text","marks":[{"type":"code"}],"text":"context.data.billing"},{"type":"text","text":" 与 "},{"type":"text","marks":[{"type":"code"}],"text":"context.data.categories"},{"type":"text","text":" 访问账单与分类数据。出于安全与稳定性考虑，运行时会剥离潜在危险的全局 API（如 "},{"type":"text","marks":[{"type":"code"}],"text":"eval"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"Function"},{"type":"text","text":" / 网络套接字）。详情见规范文档： "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://github.com/glink25/Cent/blob/main/src/components/widget/core/WIDGET_API.md","target":"_blank","rel":"noreferer","class":null}}],"text":"src/components/widget/core/WIDGET_API.md"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"实用提示与常见坑"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"保持渲染函数为纯函数：不要在运行时修改外部状态或调用长时阻塞的网络请求（渲染超时为 2000ms）。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"使用 "},{"type":"text","marks":[{"type":"code"}],"text":"settings"},{"type":"text","text":" 提供灵活性：尽量将可变参数放在 "},{"type":"text","marks":[{"type":"code"}],"text":"config"},{"type":"text","text":" 中，让最终用户能通过表单调整行为。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"对数据做稳健判断："},{"type":"text","marks":[{"type":"code"}],"text":"context.data"},{"type":"text","text":" 中的字段可能为 "},{"type":"text","marks":[{"type":"code"}],"text":"undefined"},{"type":"text","text":"（未授权），请使用默认值以避免运行时错误。"}]}]}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"发布与在首页展示"},{"type":"text","text":" 编辑器中保存并启用 "},{"type":"text","marks":[{"type":"code"}],"text":"showInHome"},{"type":"text","text":"（或在 Widget 列表中切换开关），已启用的 Widget 会出现在首页（"},{"type":"text","marks":[{"type":"code"}],"text":"src/pages/home/index.tsx"},{"type":"text","text":"），以横向滑动容器的形式显示，用户可通过滑动或切换查看多个 Widget。"}]},{"type":"paragraph","content":[{"type":"text","text":"Widget API 为 Cent 提供了一条平衡灵活性与安全性的可扩展路径：开发者可以用熟悉的 JavaScript 定制数据展示，而普通用户能通过自动生成的表单调整参数并实时预览效果。"}]}]}