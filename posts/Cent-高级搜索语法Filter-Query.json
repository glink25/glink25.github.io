e"}],"text":"time:[2025-01-01 TO 2025-03-31]"},{"type":"text","text":"时间区间"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"time"},{"type":"text","text":" 在等号场景按「同一天」匹配（忽略时分秒）。要精确小时级，请用 ISO 时间戳并搭配 "},{"type":"text","marks":[{"type":"code"}],"text":">="},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"<="},{"type":"text","text":"。"}]}]},{"type":"heading","attrs":{"level":3,"id":"布尔逻辑"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"布尔逻辑"}]},{"type":"paragraph","content":[{"type":"text","text":"逻辑写法（任选其一）与"},{"type":"text","marks":[{"type":"code"}],"text":"AND"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"&&"},{"type":"text","text":"，或 "},{"type":"text","marks":[{"type":"bold"}],"text":"直接相邻"},{"type":"text","text":"（隐式 AND）或"},{"type":"text","marks":[{"type":"code"}],"text":"OR"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"||"},{"type":"text","text":"非"},{"type":"text","marks":[{"type":"code"}],"text":"NOT"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"!"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"-"},{"type":"text","text":" 前缀分组"},{"type":"text","marks":[{"type":"code"}],"text":"( ... )"}]},{"type":"codeBlock","attrs":{"language":null},"content":[{"type":"text","text":"q:晚餐 amount:>100        # 隐式 AND：备注含\"晚餐\" 且 金额>100\nq:(tag:旅行 OR tag:出差) AND -has:scheduled\nq:!type:income            # 不是收入\n"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"优先级："},{"type":"text","marks":[{"type":"code"}],"text":"NOT > AND > OR"},{"type":"text","text":"。如不确定，加括号。"}]}]},{"type":"heading","attrs":{"level":3,"id":"引号与空格"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"引号与空格"}]},{"type":"paragraph","content":[{"type":"text","text":"值里包含空格、冒号或括号，请用双引号包裹："}]},{"type":"codeBlock","attrs":{"language":null},"content":[{"type":"text","text":"q:comment:\"家庭 聚餐\"\nq:tag:\"项目 Alpha\"\n"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2,"id":"ID-vs-名称自动两种都认"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"ID vs 名称：自动两种都认"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"category"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"tag"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"creator"},{"type":"text","text":" 这类字段背后都是 "},{"type":"text","marks":[{"type":"code"}],"text":"{id, name}"},{"type":"text","text":" 的实体。语法允许你随便用："}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"输入 "},{"type":"text","marks":[{"type":"bold"}],"text":"名称"},{"type":"text","text":"（如 "},{"type":"text","marks":[{"type":"code"}],"text":"category:餐饮"},{"type":"text","text":"）→ 系统自动翻译成对应 ID 再去匹配；"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"输入 "},{"type":"text","marks":[{"type":"bold"}],"text":"ID"},{"type":"text","text":"（如 "},{"type":"text","marks":[{"type":"code"}],"text":"category:cat_abc123"},{"type":"text","text":"）→ 直接按 ID 匹配；"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"同名实体（比如两个都叫\"打车\"的标签）→ 全部命中，符合直觉；"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"名称在元数据里"},{"type":"text","marks":[{"type":"bold"}],"text":"不存在"},{"type":"text","text":" → 退化为按字面量匹配，不会报错（也就不会命中任何账单）。"}]}]}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"优先推荐用名称——更直觉、可读性更好。需要分享/导出查询语句、且要保证语义不随重命名漂移时，才需要切到 ID。"}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2,"id":"实战案例"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"实战案例"}]},{"type":"codeBlock","attrs":{"language":null},"content":[{"type":"text","text":"# 1. 找出本月所有大于 500 元的非周期支出\nq:type:expense AND amount:>500 AND recent:1M AND -has:scheduled\n\n# 2. 旅行相关消费——餐饮或交通分类，限定 USD\nq:(category:餐饮 OR category:交通) AND tag:旅行 AND currency:USD\n\n# 3. 备注里有\"报销\"但还没贴发票（无图片）\nq:报销 AND -has:assets\n\n# 4. 所有非\"日常\"分类的小额收入\nq:type:income AND amount:<100 AND -category:日常\n\n# 5. 上半年餐饮 + 标签为家庭的所有账单\nq:category:餐饮 AND tag:家庭 AND time:[2025-01-01 TO 2025-06-30]\n"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2,"id":"实现速览给开发者"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"实现速览（给开发者）"}]},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"src/ledger/filter-query/index.ts"},{"type":"text","text":" 是一个三段式纯管道："}]},{"type":"codeBlock","attrs":{"language":null},"content":[{"type":"text","text":"parseFilterQuery(query)        : string → RawAST | null      // 不依赖任何外部状态\ncompileFilterQuery(ast, ctx)   : RawAST × Context → CompiledAST | null\n                                                              // 在此把 name 解析为 id、field 收敛为类型化节点\nmatchFilterQuery(compiled, bill): CompiledAST × Bill → boolean\n                                                              // 纯求值，零 context 依赖\n"}]},{"type":"paragraph","content":[{"type":"text","text":"热路径请用 "},{"type":"text","marks":[{"type":"code"}],"text":"createBillMatcher(filter, ctx)"},{"type":"text","text":"（"},{"type":"text","marks":[{"type":"code"}],"text":"src/ledger/utils.ts"},{"type":"text","text":"）：parse + compile 仅在创建闭包时执行一次，每个 bill 只走最后一段求值——和直接的 "},{"type":"text","marks":[{"type":"code"}],"text":"filter.includes(...)"},{"type":"text","text":" 同量级开销。"}]},{"type":"codeBlock","attrs":{"language":"ts"},"content":[{"type":"text","text":"import { createBillMatcher } from \"@/ledger/utils\";\n\nconst matcher = createBillMatcher(filter, {\n    categories: allCategories,\n    tags: allTags,\n    users: allUsers,\n    baseCurrency: meta.baseCurrency,\n});\n\nconst result = bills.filter(matcher);\n"}]},{"type":"paragraph","content":[{"type":"text","text":"设计上没有任何模块级可变状态，AST/Context 都是纯数据，可以原样移植到 Swift / Kotlin / Rust（带关联值的 enum + 普通函数）。"}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2,"id":"已知限制与扩展方向"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"已知限制与扩展方向"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"当前 "},{"type":"text","marks":[{"type":"code"}],"text":"time:>2025-01-01"},{"type":"text","text":" 在等号语义里按「同一天」匹配；需要精确到小时/分钟，请改用 ISO 完整时间戳 + "},{"type":"text","marks":[{"type":"code"}],"text":">="},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"<="},{"type":"text","text":"。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"不支持模糊匹配（"},{"type":"text","marks":[{"type":"code"}],"text":"*"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"~"},{"type":"text","text":"）和正则——备注子串匹配走的是 "},{"type":"text","marks":[{"type":"code"}],"text":"String.includes"},{"type":"text","text":"。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"code"}],"text":"recent"},{"type":"text","text":" 的 unit 透传给 "},{"type":"text","marks":[{"type":"code"}],"text":"dayjs.subtract"},{"type":"text","text":"，常用 "},{"type":"text","marks":[{"type":"code"}],"text":"d"},{"type":"text","text":"（天）/"},{"type":"text","marks":[{"type":"code"}],"text":"w"},{"type":"text","text":"（周）/"},{"type":"text","marks":[{"type":"code"}],"text":"M"},{"type":"text","text":"（月）/"},{"type":"text","marks":[{"type":"code"}],"text":"y"},{"type":"text","text":"（年）。注意 "},{"type":"text","marks":[{"type":"code"}],"text":"M"},{"type":"text","text":" 是月、"},{"type":"text","marks":[{"type":"code"}],"text":"m"},{"type":"text","text":" 是分钟。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"没有缓存层——"},{"type":"text","marks":[{"type":"code"}],"text":"createBillMatcher"},{"type":"text","text":" 每次创建都会 parse+compile。如果你在 UI 里需要响应式，把它包在 "},{"type":"text","marks":[{"type":"code"}],"text":"useMemo"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"computed"},{"type":"text","text":" 里。"}]}]}]}]}