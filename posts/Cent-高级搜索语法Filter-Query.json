天的支出"},{"type":"text","marks":[{"type":"code"}],"text":"q:recent:7d AND type:expense"}]},{"type":"blockquote","content":[{"type":"paragraph","content":[{"type":"text","text":"触发前缀只识别第一个非空白字符开始的 "},{"type":"text","marks":[{"type":"code"}],"text":"q:"},{"type":"text","text":"。"},{"type":"text","marks":[{"type":"code"}],"text":"q:"},{"type":"text","text":" 之后才是真正的查询语句。"}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2,"id":"字段速查表"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"字段速查表"}]},{"type":"paragraph","content":[{"type":"text","text":"字段含义示例"},{"type":"text","marks":[{"type":"code"}],"text":"type"},{"type":"text","text":"账单类型，"},{"type":"text","marks":[{"type":"code"}],"text":"income"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"expensetype:expensecategory"},{"type":"text","text":"分类。可填 ID 或名称"},{"type":"text","marks":[{"type":"code"}],"text":"category:餐饮tag"},{"type":"text","text":"标签。可填 ID 或名称，多个标签用 OR / AND 自行组合"},{"type":"text","marks":[{"type":"code"}],"text":"tag:旅行creator"},{"type":"text","text":" / "},{"type":"text","marks":[{"type":"code"}],"text":"user"},{"type":"text","text":"记账人"},{"type":"text","marks":[{"type":"code"}],"text":"creator:张三currency"},{"type":"text","text":"币种代码"},{"type":"text","marks":[{"type":"code"}],"text":"currency:USDamount"},{"type":"text","text":"金额（数值）"},{"type":"text","marks":[{"type":"code"}],"text":"amount:>100"},{"type":"text","text":"、"},{"type":"text","marks":[{"type":"code"}],"text":"amount:[50 TO 200]time"},{"type":"text","text":"账单发生时间，支持 ISO 日期"},{"type":"text","marks":[{"type":"code"}],"text":"time:>=2025-01-01recent"},{"type":"text","text":"相对时间："},{"type":"text","marks":[{"type":"code"}],"text":"d"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"w"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"M"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"code"}],"text":"y"},{"type":"text"