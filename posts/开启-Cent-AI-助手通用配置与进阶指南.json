":"text","text":"（参考此文完成代理部署）。"}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2,"id":"三-测试与保存"},"content":[{"type":"text","text":"三、 测试与保存"}]},{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"点击 [测试连接]"},{"type":"text","text":"："}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"如果提示"},{"type":"text","marks":[{"type":"bold"}],"text":"成功"},{"type":"text","text":"：说明你的代理地址、Key 和模型名称均配置无误。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"如果提示"},{"type":"text","marks":[{"type":"bold"}],"text":"失败"},{"type":"text","text":"：请优先检查你的代理服务器是否正常工作，以及 API Key 是否有余额。"}]}]}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"点击 [保存]"},{"type":"text","text":"：保存后，你就可以在账单页面使用 AI 语音或文字记账了。"}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2,"id":"四-常见问题-FAQ"},"content":[{"type":"text","text":"四、 常见问题 (FAQ)"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"所有的 AI 厂商都需要代理吗？"}]},{"type":"paragraph","content":[{"type":"text","text":"极少数厂商可能默认允许网页跨域，例如。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"为什么我保存后 AI 没有反应？"}]},{"type":"paragraph","content":[{"type":"text","text":"请确认在“模型”一栏填写的名称是否与厂商要求完全一致（注意大小写和连字符）。"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"数据安全吗？"}]},{"type":"paragraph","content":[{"type":"text","text":"Cent 会通过云同步你的配置以便多端使用，但你的 API Key 对其他协作成员是不可见的。"}]}]}]},{"type":"horizontalRule"},{"type":"paragraph","content":[{"type":"text","marks":[{"type":"bold"}],"text":"完成以上设置后，你的 Cent 记账 App 就正式接入“大脑”了！"}]},{"type":"