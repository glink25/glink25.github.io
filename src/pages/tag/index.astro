---
import Layout from "../../layouts/Layout.astro";
import type { PageData } from "../../shared/type";
import { getPageList } from "../api/post/list";

const posts = await getPageList();
const tags = [...new Set(posts.map((p) => p.tags).flat())];
---

<Layout title="Tags">
  <main>
    <div class="content flex items-center justify-center px-4 gap-4">
      {
        tags.map((tag) => (
          <a
            href={`/tag/${encodeURIComponent(tag)}`}
            class="text-4xl text-black text-opacity-60 hover:text-opacity-100"
          >
            #{decodeURIComponent(tag)}
          </a>
        ))
      }
    </div>
  </main>
</Layout>
